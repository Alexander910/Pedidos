{
  "name": "envios-ya-functions",
  "version": "1.0.0",
  "private": true,
  "description": "Firebase Cloud Functions for ENVIOS-YA dispatcher rules, payments, and social integrations",
  "main": "lib/index.js",
  "scripts": {
    "lint": "eslint --ext .js,.ts .",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions"
  },
  "engines": {
    "node": "18"
  },
  "dependencies": {
    "firebase-admin": "^11.8.0",
    "firebase-functions": "^4.3.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "typescript": "^5.2.2"
  }
}
