rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic helpers
    function isSignedIn() {
      return request.auth != null;
    }
    function getUserRole(auth) {
      return auth.token.role != null 
        ? auth.token.role 
        : (exists(/databases/$(database)/documents/users/$(auth.uid))
            ? ('role' in get(/databases/$(database)/documents/users/$(auth.uid)).data
                ? get(/databases/$(database)/documents/users/$(auth.uid)).data.role
                : 'client')
            : 'client');
    }
    function getUserCompanyId(auth) {
      return exists(/databases/$(database)/documents/users/$(auth.uid))
        ? ('companyId' in get(/databases/$(database)/documents/users/$(auth.uid)).data
            ? get(/databases/$(database)/documents/users/$(auth.uid)).data.companyId
            : '')
        : '';
    }
    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // Profiles
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(uid);
      allow update: if isSignedIn() && (isOwner(uid) || getUserRole(request.auth) == 'admin');
      allow delete: if isSignedIn() && getUserRole(request.auth) == 'admin';
    }

    // Drivers GPS and statistics
    match /drivers/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isOwner(uid) || getUserRole(request.auth) == 'admin' || getUserRole(request.auth) == 'dispatcher');
    }

    // Companies
    match /companies/{companyId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (getUserRole(request.auth) == 'admin' || getUserRole(request.auth) == 'super_admin');
    }

    // Clients profile metadata
    match /clients/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isOwner(uid) || getUserRole(request.auth) == 'admin');
    }

    // Orders logistics data
    match /orders/{orderId} {
      allow read: if isSignedIn() && (
        getUserRole(request.auth) == 'admin' || 
        getUserRole(request.auth) == 'dispatcher' || 
        resource.data.clientId == request.auth.uid || 
        resource.data.clientId == getUserCompanyId(request.auth) ||
        resource.data.driverId == request.auth.uid
      );
      // Create is allowed for clients and dispatchers
      allow create: if isSignedIn() && (getUserRole(request.auth) == 'client' || getUserRole(request.auth) == 'dispatcher' || getUserRole(request.auth) == 'admin');
      // Updates are validated
      allow update: if isSignedIn() && (
        getUserRole(request.auth) == 'admin' || 
        getUserRole(request.auth) == 'dispatcher' ||
        resource.data.driverId == request.auth.uid
      );
      allow delete: if isSignedIn() && getUserRole(request.auth) == 'admin';
    }

    // Transactions ledgers (read-only for drivers/clients, write-only for admins)
    match /transactions/{txnId} {
      allow read: if isSignedIn() && (getUserRole(request.auth) == 'admin' || resource.data.driverId == request.auth.uid);
      allow write: if isSignedIn() && getUserRole(request.auth) == 'admin';
    }
  }
}
