rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic helpers
    function isSignedIn() {
      return request.auth != null;
    }
    function getUserRole() {
      return request.auth.token.role != null 
        ? request.auth.token.role 
        : (exists(/databases/$(database)/documents/users/$(request.auth.uid))
            ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'client')
            : 'client');
    }
    function getUserCompanyId() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('companyId', '')
        : '';
    }
    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // Profiles
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(uid);
      allow update: if isSignedIn() && (isOwner(uid) || getUserRole() == 'admin');
      allow delete: if isSignedIn() && getUserRole() == 'admin';
    }

    // Drivers GPS and statistics
    match /drivers/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isOwner(uid) || getUserRole() == 'admin' || getUserRole() == 'dispatcher');
    }

    // Companies
    match /companies/{companyId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (getUserRole() == 'admin' || getUserRole() == 'super_admin');
    }

    // Clients profile metadata
    match /clients/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isOwner(uid) || getUserRole() == 'admin');
    }

    // Orders logistics data
    match /orders/{orderId} {
      allow read: if isSignedIn() && (
        getUserRole() == 'admin' || 
        getUserRole() == 'dispatcher' || 
        resource.data.clientId == request.auth.uid || 
        resource.data.clientId == getUserCompanyId() ||
        resource.data.driverId == request.auth.uid
      );
      // Create is allowed for clients and dispatchers
      allow create: if isSignedIn() && (getUserRole() == 'client' || getUserRole() == 'dispatcher' || getUserRole() == 'admin');
      // Updates are validated
      allow update: if isSignedIn() && (
        getUserRole() == 'admin' || 
        getUserRole() == 'dispatcher' ||
        resource.data.driverId == request.auth.uid
      );
      allow delete: if isSignedIn() && getUserRole() == 'admin';
    }

    // Transactions ledgers (read-only for drivers/clients, write-only for admins)
    match /transactions/{txnId} {
      allow read: if isSignedIn() && (getUserRole() == 'admin' || resource.data.driverId == request.auth.uid);
      allow write: if isSignedIn() && getUserRole() == 'admin';
    }
  }
}
